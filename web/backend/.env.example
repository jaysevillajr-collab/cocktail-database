# Backend environment configuration
# Copy to .env and customize values as needed.

# Optional DB override (defaults to {install_dir}\cocktail_database.db)
# COCKTAIL_DB_PATH=C:\Path\To\cocktail_database.db

# Optional image storage override (defaults to {install_dir}\images)
# COCKTAIL_IMAGES_PATH=C:\Path\To\images

# Groq (optional)
# GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20

# Gemini (optional)
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=20
